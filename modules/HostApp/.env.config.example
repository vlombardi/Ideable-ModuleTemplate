############################
# HostApp Module Settings  #
############################

# ════════════════════════════════════════════════════════════════
#  Ports & Paths
# ════════════════════════════════════════════════════════════════

######################
# Hosts configurations #
######################
MAIN_HOST=localhost
DATABASE_IP=${MAIN_HOST}

################################
# TLS / Reverse Proxy (Traefik) #
################################
# Manual certificate paths inside the Traefik container (used when TLS_MODE=manual)
TLS_CERT_PATH=/certs/fullchain.pem
TLS_KEY_PATH=/certs/privkey.pem

# Traefik entrypoint ports on the host (canonical values in project.env.config)
TRAEFIK_HTTP_PORT=${HOSTAPP_TRAEFIK_HTTP_PORT:-80}
TRAEFIK_HTTPS_PORT=${HOSTAPP_TRAEFIK_HTTPS_PORT:-443}
TRAEFIK_DASHBOARD_PORT=${HOSTAPP_TRAEFIK_DASHBOARD_PORT:-8088}

#################
# Service Ports #
#################
# All exposed port values are defined in project.env.config and referenced here.
# Use adjust-exposed-ports.sh to change them without editing this file.

# Frontend
FRONTEND_EXTERNAL_PORT=3001
FRONTEND_PORT=${HOSTAPP_FRONTEND_PORT:-3000}
AUTHENTIK_PORT_HTTP=${HOSTAPP_AUTHENTIK_HTTP_PORT:-9000}
AUTHENTIK_PORT_HTTPS=${HOSTAPP_AUTHENTIK_HTTPS_PORT:-9443}

# Backend
BACKEND_PORT=${HOSTAPP_BACKEND_PORT:-8001}

##########################
# Frontend Configuration #
##########################
FRONTEND_CERT_HOSTS=${MAIN_HOST},localhost,127.0.0.1,${EXTERNAL_BASE_HOST}
FRONTEND_CERT_IP=${MAIN_HOST}

##########################
# Database Configuration #
##########################
POSTGRES_HOST=${DATABASE_IP}
POSTGRES_USER=ideable_db_user
POSTGRES_DB=ideable_db
# External exposed port (canonical value in project.env.config)
POSTGRES_PORT=${HOSTAPP_POSTGRES_PORT:-5433}
# Connection string (external access potentially? No, typically internal for services. But usually internal is hostname based port 5432)
# Here DATABASE_URL uses POSTGRES_PORT, careful. If external, use 5433. If internal, usually hardcoded to database:5432 in docker-compose.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

###########################
# Authentik Configuration #
###########################
# External URL at which Authentik is exposed (path-based under the main host)
AUTHENTIK_EXTERNAL_URL=https://${EXTERNAL_BASE_HOST}/auth

# Authentik database (uses the existing Timescale/Postgres instance)
AUTHENTIK_POSTGRES_HOST=database
AUTHENTIK_POSTGRES_PORT=5432 # Internal port

# ════════════════════════════════════════════════════════════════
#  Params
# ════════════════════════════════════════════════════════════════

# Module identity (module-local)
MODULE_SLUG=hostapp
MODULE_NAME=HostApp

# Registry prefix for this module's images (used by push script and compose references).
# When set, compose image references include this prefix with a slash separator:
#   image: ${MODULE_DOCKER_REGISTRY_PREFIX}/${MODULE_SLUG}.backend:latest
# The value should NOT include a trailing slash (e.g. ghcr.io/OWNER).
# Note: when this module is declared as "local" (not "remote") in modules/enabled.md,
# the deploy script strips the prefix at compose generation time so compose uses locally built images.
# Leave empty for local builds (no registry prefix).
MODULE_DOCKER_REGISTRY_PREFIX=ghcr.io/vlombardi

# When true, the app name is shown in the HostApp header next to the logo.
# When false, only the logo is displayed and the app name is hidden.
SHOW_APP_NAME_ON_HEADER=true

AUTHENTIK_LOGIN_BG_IMAGE_FILE=config/login_bg.png
AUTHENTIK_LOGIN_FAVICON_FILE=config/favicon.png
AUTHENTIK_LOGIN_BG_COLOR="#ffffff"

# Internationalization
# System-wide default language (used as fallback when user/tenant default_language is not set)
DEFAULT_LANGUAGE=en
VITE_DEFAULT_LANGUAGE=${DEFAULT_LANGUAGE}

# OIDC client_id used by Authentik for the OAuth2/OIDC application.
CLIENT_ID=${APP_SLUG}-client

# Mode for TLS certificates at the reverse proxy.
# Supported values (for now):
#   letsencrypt - Traefik obtains certificates via Let's Encrypt ACME
#   manual      - Traefik uses certificates mounted into the container
TLS_MODE=letsencrypt

# Let's Encrypt configuration (used when TLS_MODE=letsencrypt)
LE_EMAIL=admin@ideable.tech
ACME_EMAIL=${LE_EMAIL}
LE_STAGING=true

TRAEFIK_LOG_LEVEL=INFO

###########################
# Authentik Configuration #
###########################
# Bootstrap admin user for Authentik (set real values only in .env.secrets)
AUTHENTIK_BOOTSTRAP_EMAIL=sadmin@localhost

# Backend Authentik API settings used by the FastAPI backend
AUTHENTIK_JWKS_URL=http://authentik-server:9000/application/o/${APP_SLUG}/jwks/
AUTHENTIK_API_URL=http://authentik-server:9000/api/v3

AUTHENTIK_POSTGRES_DB=authentik
AUTHENTIK_POSTGRES_USER=${POSTGRES_USER}

SADMIN_IS_SUPERUSER=true

# Authentik provider token lifetimes use the Authentik duration format:
#   seconds=30, minutes=5, hours=1, days=30

# AUTHENTIK_ACCESS_CODE_VALIDITY: short-lived authorization code issued during the
#   login redirect flow; keep this short because it is exchanged immediately.
AUTHENTIK_ACCESS_CODE_VALIDITY=minutes=1

# AUTHENTIK_ACCESS_TOKEN_VALIDITY: lifetime of the access token used on API calls;
#   increase this if users are being logged out too quickly.
#   Example: AUTHENTIK_ACCESS_TOKEN_VALIDITY=hours=8
AUTHENTIK_ACCESS_TOKEN_VALIDITY=minutes=5

# AUTHENTIK_REFRESH_TOKEN_VALIDITY: lifetime of the refresh token used for silent
#   renew; keep this longer than the access token so refresh can continue working.
AUTHENTIK_REFRESH_TOKEN_VALIDITY=days=30

#########################
# Backend Auth Settings #
#########################
# Internal URL to reach Authentik from backend container (for JWKS fetching)
AUTHENTIK_INTERNAL_URL=http://authentik-server:9000

# JWKS URL is derived automatically: ${AUTHENTIK_INTERNAL_URL}/application/o/${APP_SLUG}/jwks/
# Override only if your provider slug differs.
# AUTHENTIK_JWKS_URL=http://authentik-server:9000/application/o/digitalshelter/jwks/

# Set to "false" in local dev to skip JWT signature validation (default: true)
JWT_VALIDATION_ENABLED=true

# Comma-separated list of public (unauthenticated) backend paths
PUBLIC_PATHS=/health,/openapi.json

#########################
# Frontend Configuration #
#########################
VITE_APP_TITLE=${APP_NAME}
VITE_SHOW_APP_NAME_ON_HEADER=${SHOW_APP_NAME_ON_HEADER}
VITE_API_URL=https://${EXTERNAL_BASE_HOST}/api
VITE_OIDC_AUTHORITY=https://${EXTERNAL_BASE_HOST}/application/o/${APP_SLUG}/
VITE_OIDC_CLIENT_ID=${CLIENT_ID}
VITE_OIDC_REDIRECT_URI=https://${EXTERNAL_BASE_HOST}/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=https://${EXTERNAL_BASE_HOST}

#########################
# Backend Configuration #
#########################
# CORS - Set to "true" only in development to allow all origins
# In production, only EXTERNAL_BASE_HOST and localhost will be allowed
CORS_ALLOW_ALL=false

# Application Versions
TIMESCALEDB_VERSION=2.18.2-pg16
NODE_JS_VERSION=18
AUTHENTIK_VERSION=2025.10.4
IDEABLE_VERSION=latest
