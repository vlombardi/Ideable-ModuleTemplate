# HostApp Module Secrets — example values
# Copy to .env.secrets and replace placeholders with real values.
# WARNING: Do not commit .env.secrets to version control.

##########################
# Database Configuration #
##########################
POSTGRES_PASSWORD=${HOSTAPP_POSTGRES_PASSWORD}

###########################
# Authentik Configuration #
###########################
AUTHENTIK_BOOTSTRAP_PASSWORD=${HOSTAPP_AUTHENTIK_BOOTSTRAP_PASSWORD}
AUTHENTIK_BOOTSTRAP_TOKEN=${HOSTAPP_AUTHENTIK_BOOTSTRAP_TOKEN}
AUTHENTIK_API_TOKEN=${AUTHENTIK_BOOTSTRAP_TOKEN}
AUTHENTIK_POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

# Secret key for Authentik (must be overridden, do not use this default in production)
AUTHENTIK_SECRET_KEY=${HOSTAPP_AUTHENTIK_SECRET_KEY}
CLIENT_SECRET=${HOSTAPP_CLIENT_SECRET}
SERVICE_CLIENT_SECRET=${HOSTAPP_SERVICE_CLIENT_SECRET}
