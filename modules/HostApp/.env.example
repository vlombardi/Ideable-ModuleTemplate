##########################
# External DNS / Routing #
##########################
EXTERNAL_BASE_HOST=localhost

################################
# TLS / Reverse Proxy (Traefik) #
################################
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8088
TRAEFIK_LOG_LEVEL=INFO
ACME_EMAIL=admin@localhost

#################
# Service Ports #
#################
FRONTEND_PORT=3000
BACKEND_PORT=8001
POSTGRES_PORT=5433
AUTHENTIK_PORT_HTTP=9000
AUTHENTIK_PORT_HTTPS=9443

##########################
# Database Configuration #
##########################
POSTGRES_HOST=database
POSTGRES_USER=vinz
POSTGRES_PASSWORD=vinz
POSTGRES_DB=vinz
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

###########################
# Authentik Configuration #
###########################
AUTHENTIK_POSTGRES_HOST=database
AUTHENTIK_POSTGRES_PORT=5432
AUTHENTIK_POSTGRES_DB=authentik
AUTHENTIK_POSTGRES_USER=vinz
AUTHENTIK_POSTGRES_PASSWORD=vinz
# Used by Authentik to encrypt sensitive data. Must be set to a strong value in real .env.
AUTHENTIK_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_SECRET_KEY_MIN_50_CHARS
# Admin user created on first boot.
AUTHENTIK_BOOTSTRAP_EMAIL=admin@localhost
AUTHENTIK_BOOTSTRAP_PASSWORD=admin
# Token used by the bootstrap script to configure Authentik via API.
AUTHENTIK_BOOTSTRAP_TOKEN=authentik-bootstrap-token

#########################
# Application Settings  #
#########################
# APP_SLUG is the primary identifier used across docker-compose for container/image naming
# and Authentik application/provider slugs. Keep it stable and (recommended) lowercase.
APP_SLUG=ideable
# Human-readable application name used in UI and Authentik application display name.
APP_NAME=${APP_SLUG}
# OIDC client_id used by Authentik for the OAuth2/OIDC application.
CLIENT_ID=${APP_SLUG}-client
# OIDC client_secret (set to a strong value in real .env; may be unused for public clients).
CLIENT_SECRET=CHANGE_ME_IN_PRODUCTION_CLIENT_SECRET

#########################
# Backend Configuration #
#########################
AUTHENTIK_INTERNAL_URL=http://authentik-server:${AUTHENTIK_PORT_HTTP}
AUTHENTIK_JWKS_URL=http://authentik-server:9000/application/o/${APP_SLUG}/jwks/
AUTHENTIK_API_URL=http://authentik-server:9000/api/v3
AUTHENTIK_API_TOKEN=${AUTHENTIK_BOOTSTRAP_TOKEN}

#########################
# Frontend Configuration #
#########################
# These are consumed by the Vite build (frontend container image). They must be set.
VITE_APP_TITLE=${APP_NAME}
VITE_API_URL=http://localhost:${BACKEND_PORT}
VITE_OIDC_AUTHORITY=http://localhost:${AUTHENTIK_PORT_HTTP}/application/o/${APP_SLUG}/
VITE_OIDC_CLIENT_ID=${CLIENT_ID}
VITE_OIDC_REDIRECT_URI=http://localhost:${FRONTEND_PORT}/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:${FRONTEND_PORT}

# Core Services Versions
TIMESCALEDB_VERSION=2.18.2-pg16
AUTHENTIK_VERSION=2025.10.4