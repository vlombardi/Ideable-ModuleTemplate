# module_template configuration — example values
# Copy to .env.config and adjust values for your module.

# ════════════════════════════════════════════════════════════════
#  Ports & Paths
# ════════════════════════════════════════════════════════════════

# module_template entities DB target (used by template-backend).
# Defaults to the dedicated template-database service.
TEMPLATE_ENTITIES_DB_HOST=template-database
TEMPLATE_ENTITIES_DB_PORT=5432

# Published host port for template-database (canonical value in project.env.config).
# Renamed by module-init.sh to <MODULE>_POSTGRES_PORT.
TEMPLATE_POSTGRES_PORT=${IDEABLE_MODULE_POSTGRES_PORT:-5434}

# Backend and frontend exposed ports (canonical values in project.env.config).
# Renamed by module-init.sh to <MODULE>_BACKEND_PORT and <MODULE>_FRONTEND_PORT.
TEMPLATE_BACKEND_PORT=${IDEABLE_MODULE_BACKEND_PORT:-8002}
TEMPLATE_FRONTEND_PORT=${IDEABLE_MODULE_FRONTEND_PORT:-3001}

# host_app integration — uses host_app's APP_SLUG (always 'ideable' for this platform)
HOSTAPP_API_URL=http://backend:8001
HOSTAPP_DB_HOST=database
HOSTAPP_DB_PORT=5432

MODULE_SWAGGER_CALLBACK_URL=/module/template/api/docs/oauth2-redirect

# Frontend build-time variables (passed as Docker build args)
VITE_TEMPLATE_API_URL=/module/template/api

# ════════════════════════════════════════════════════════════════
#  Params
# ════════════════════════════════════════════════════════════════

# Module identity (module-local)
MODULE_SLUG=template
MODULE_NAME=module_template

# Registry prefix for this module's images (used by push script and compose references).
# When set, compose image references include this prefix with a slash separator:
#   image: ${MODULE_DOCKER_REGISTRY_PREFIX}/${MODULE_SLUG}.backend:latest
# The value should NOT include a trailing slash (e.g. ghcr.io/OWNER).
# Note: when this module is declared as "local" (not "remote") in modules/enabled.md,
# the deploy script strips the prefix at compose generation time so compose uses locally built images.
# Leave empty for local builds (no registry prefix).
MODULE_DOCKER_REGISTRY_PREFIX=

TEMPLATE_ENTITIES_DB_NAME=template_db
TEMPLATE_ENTITIES_DB_USER=template_user

AUTHENTIK_JWKS_URL=http://authentik-server:9000/application/o/ideable/jwks/

# OIDC / Swagger integration for the remote frontend and backend docs.
VITE_OIDC_AUTHORITY=https://mydomain.com/application/o/ideable/
VITE_OIDC_CLIENT_ID=ideable-client
VITE_OIDC_REDIRECT_URI=https://mydomain.com/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=https://mydomain.com

HOSTAPP_DB_NAME=vinz
HOSTAPP_DB_USER=vinz

VITE_TEMPLATE_LF_MODE=hostapp
