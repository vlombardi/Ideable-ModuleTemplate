APP_SLUG=template
APP_NAME=ModuleTemplate

# ModuleTemplate entities DB target (used by template-backend).
# Defaults to the dedicated template-database service.
TEMPLATE_ENTITIES_DB_HOST=template-database
TEMPLATE_ENTITIES_DB_PORT=5432
TEMPLATE_ENTITIES_DB_NAME=template_db
TEMPLATE_ENTITIES_DB_USER=template_user
TEMPLATE_ENTITIES_DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ModuleTemplate authorization DB target (used by authorization.sql bootstrap).
# Defaults to HostApp DB because authorization is centralized there.
TEMPLATE_AUTH_DB_HOST=database
TEMPLATE_AUTH_DB_PORT=5432
TEMPLATE_AUTH_DB_NAME=vinz
TEMPLATE_AUTH_DB_USER=vinz
TEMPLATE_AUTH_DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Published host port for template-database when it is enabled.
TEMPLATE_POSTGRES_PORT=5434

TEMPLATE_BACKEND_PORT=8002
TEMPLATE_FRONTEND_PORT=3001

# HostApp integration — uses HostApp's APP_SLUG (always 'ideable' for this platform)
AUTHENTIK_JWKS_URL=http://authentik-server:9000/application/o/ideable/jwks/
HOSTAPP_API_URL=http://backend:8001

# HostApp DB credentials — required if template shares the HostApp DB for authorization
HOSTAPP_DB_HOST=database
HOSTAPP_DB_PORT=5432
HOSTAPP_DB_NAME=vinz
HOSTAPP_DB_USER=vinz
HOSTAPP_DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Frontend build-time variables (passed as Docker build args)
VITE_TEMPLATE_API_URL=/module/template/api
VITE_TEMPLATE_LF_MODE=hostapp
