# ModuleTemplate configuration
# Copy to .env.config and adjust values for your module.

# ════════════════════════════════════════════════════════════════
#  Ports & Paths
# ════════════════════════════════════════════════════════════════

# ModuleTemplate entities DB target (used by template-backend).
# Defaults to the dedicated template-database service.
TEMPLATE_ENTITIES_DB_HOST=template-database
TEMPLATE_ENTITIES_DB_PORT=5432

# ModuleTemplate authorization DB target (used by authorization.yaml bootstrap input).
# Defaults to HostApp DB because authorization is centralized there.
TEMPLATE_AUTH_DB_HOST=database
TEMPLATE_AUTH_DB_PORT=5432

# Published host port for template-database when it is enabled.
TEMPLATE_POSTGRES_PORT=5434

TEMPLATE_BACKEND_PORT=8002
TEMPLATE_FRONTEND_PORT=3001

# HostApp integration
HOSTAPP_API_URL=http://backend:8001
HOSTAPP_DB_HOST=database
HOSTAPP_DB_PORT=5432

# Keep this same-origin path (via Traefik) to avoid browser CORS failures that happen
# when the frontend falls back to direct localhost backend URLs from HTTPS HostApp pages.
VITE_TEMPLATE_API_URL=/module/template/api

# ════════════════════════════════════════════════════════════════
#  Params
# ════════════════════════════════════════════════════════════════

# Module identity (module-local)
MODULE_SLUG=template
MODULE_NAME=ModuleTemplate

# Registry prefix for pushing this module's images (used by push script).
# When set, compose image references that will be pulled from a remote registry
# must already include this prefix (e.g. ghcr.io/owner/template.backend:latest).
# Note: when this module is declared as "local" (not "remote") in modules/enabled.md,
# the deploy script strips this prefix from deployed .env.config and .env.secrets files so compose uses locally built images.
MODULE_DOCKER_REGISTRY_PREFIX=ghcr.io/vlombardi

TEMPLATE_ENTITIES_DB_NAME=template_db
TEMPLATE_ENTITIES_DB_USER=template_user

TEMPLATE_AUTH_DB_NAME=vinz
TEMPLATE_AUTH_DB_USER=vinz

AUTHENTIK_JWKS_URL=http://authentik-server:9000/application/o/ideable/jwks/

HOSTAPP_DB_NAME=vinz
HOSTAPP_DB_USER=vinz

VITE_TEMPLATE_LF_MODE=hostapp
