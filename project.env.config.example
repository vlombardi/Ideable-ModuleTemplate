# Project-wide configuration
#
# This file defines configuration values that belong to the whole project/repository,
# not to an individual module.
#
# Copy it to `project.env.config` and adjust the values for each project.

# ════════════════════════════════════════════════════════════════
#  Ports & Paths
# ════════════════════════════════════════════════════════════════

##################################
# External DNS / Routing / Host  #
##################################
# Public DNS name used to access the system from outside.
# This is the hostname used by Traefik, Authentik and the frontend.
EXTERNAL_BASE_HOST=localhost

##################################
# host_app Exposed Ports          #
##################################
# All host_app container host-exposed ports are centralized here.
# Modules reference them via their own .env.config files.
HOSTAPP_POSTGRES_PORT=5433
HOSTAPP_BACKEND_PORT=8001
HOSTAPP_FRONTEND_PORT=3000
HOSTAPP_AUTHENTIK_HTTP_PORT=9000
HOSTAPP_AUTHENTIK_HTTPS_PORT=9443
HOSTAPP_TRAEFIK_HTTP_PORT=80
HOSTAPP_TRAEFIK_HTTPS_PORT=443
HOSTAPP_TRAEFIK_DASHBOARD_PORT=8088

##################################
# Custom Module Exposed Ports    #
##################################
# These apply to the module derived from module_template (e.g. SRA, DigitalShelter).
# They are renamed by module-init.sh in the module's .env.config, but the canonical
# values live here so configure.sh can manage them centrally.
IDEABLE_MODULE_POSTGRES_PORT=5434
IDEABLE_MODULE_BACKEND_PORT=8002
IDEABLE_MODULE_FRONTEND_PORT=3001

#################
# Project Paths #
#################
PROJECT_ROOT=<PATH_TO_PROJECT_FATHER_FOLDER>/Ideable
DATA_FOLDER=${PROJECT_ROOT}/deployment_root/data

# ════════════════════════════════════════════════════════════════
#  Params
# ════════════════════════════════════════════════════════════════

# Project identifier used for Compose project naming, host_app container prefixes,
# image tags, and other runtime-scoped resources.
APP_SLUG=ideable

# Human-readable project name used in UI and brand-facing labels.
APP_NAME=Ideable

# Image tag used by remote module repos to pull host_app images from the registry.
# Defaults to 'latest' if not set. Override to a specific version when needed.
IDEABLE_VERSION=latest
