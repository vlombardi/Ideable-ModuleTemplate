# Project-wide configuration
#
# This file defines values that belong to the whole project/repository,
# not to an individual module.
#
# Copy it to `project.env` and adjust the values for each project.

# Project identifier used for Compose project naming, HostApp container prefixes,
# image tags, and other runtime-scoped resources.
APP_SLUG=ideable

# Human-readable project name used in UI and brand-facing labels.
APP_NAME=Ideable

# Optional explicit Compose project name. If omitted, scripts should default
# to APP_SLUG.
COMPOSE_PROJECT_NAME=ideable

# Docker registry prefix used by image push scripts.
# Set this to a namespace-qualified prefix if needed (for example ghcr.io/OWNER).
# If left as plain ghcr.io, the push script expands it using the repository owner.
DOCKER_REGISTRY=ghcr.io

#################
# Project Paths #
#################
PROJECT_ROOT=<PATH_TO_PROJECT_FATHER_FOLDER>/Ideable
DATA_FOLDER=${PROJECT_ROOT}/deployment_root/data